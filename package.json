{
  "name": "next-pdf-viewer",
  "private": true,
  "version": "2.9.7",
  "productName": "Next PDF Viewer",
  "description": "Modern desktop PDF reader built with Electron, React, TypeScript, Vite, and PDF.js.",
  "author": "Nexa Nest LTD",
  "main": "electron/main.js",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:renderer\" \"npm:dev:app\"",
    "dev:renderer": "vite",
    "dev:app": "wait-on tcp:5173 && node scripts/start-electron-dev.cjs",
    "build": "tsc -b && vite build",
    "dist": "npm run build && node scripts/build-electron.cjs",
    "lint": "eslint .",
    "test:search": "node scripts/test-search-index.mjs",
    "test:references": "node scripts/test-references.mjs",
    "preview": "vite preview"
  },
  "dependencies": {
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^5.4.296",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-pdf": "^10.4.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.5.0",
    "concurrently": "^10.0.3",
    "electron": "^42.4.1",
    "electron-builder": "^26.15.3",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "postcss": "^8.5.15",
    "tailwindcss": "^3.4.17",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12",
    "wait-on": "^9.0.10"
  },
  "build": {
    "appId": "com.nexanest.nextpdfviewer",
    "productName": "Next PDF Viewer",
    "asar": true,
    "directories": {
      "buildResources": "build"
    },
    "files": [
      "dist",
      "electron/main.js",
      "electron/preload.js",
      "electron/search-index.js",
      "electron/references.js",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "build/icon.png",
        "to": "icon.png"
      }
    ],
    "extraMetadata": {
      "main": "electron/main.js"
    },
    "win": {
      "icon": "build/icon.ico",
      "target": [
        "nsis"
      ],
      "artifactName": "Next-PDF-Viewer-${version}-Setup.${ext}"
    },
    "mac": {
      "category": "public.app-category.productivity"
    },
    "linux": {
      "category": "Office"
    },
    "fileAssociations": [
      {
        "ext": "pdf",
        "name": "Next PDF Viewer PDF Document",
        "description": "PDF Document",
        "mimeType": "application/pdf",
        "icon": "icon.ico",
        "role": "Viewer"
      }
    ],
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
